# --- LOCAL (SQLite) ---
# DATABASE_URL="file:/absolute/path/to/prisma/dev.db"
# TURSO_AUTH_TOKEN=   # dejar vacío en local

# --- PRODUCCIÓN (Turso) ---
DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# WhatsApp (número sin +, ej: 5493812345678 para Tucumán)
WHATSAPP_NUMBER="5493812345678"

# Admin login — secret used to sign the admin session cookie (JWT).
# Falls back to NEXTAUTH_SECRET if unset. Generate with: openssl rand -base64 32
SESSION_SECRET="generate-a-random-string"

# Admin credentials seeded by `npm run db:seed` (the password is hashed before storing).
ADMIN_EMAIL="admin@tobias.com"
ADMIN_PASSWORD="change-me"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-string"
NEXTAUTH_URL="https://your-app.vercel.app"

# Vercel Blob (image uploads in production)
# Get this from: Vercel dashboard → Storage → Blob → Connect store → .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Borgest sync — shared secret required in the x-api-key header on POST /api/sync-productos
SYNC_API_KEY="generate-a-long-random-string"
