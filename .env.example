# --- LOCAL (SQLite) ---
# DATABASE_URL="file:/absolute/path/to/prisma/dev.db"
# TURSO_AUTH_TOKEN=   # dejar vacío en local

# --- PRODUCCIÓN (Turso) ---
DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# WhatsApp (número sin +, ej: 5493812345678 para Tucumán)
WHATSAPP_NUMBER="5493812345678"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-string"
NEXTAUTH_URL="https://your-app.vercel.app"

# Vercel Blob (image uploads in production)
# Get this from: Vercel dashboard → Storage → Blob → Connect store → .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
