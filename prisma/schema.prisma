generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  emoji     String    @default("")
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id               Int             @id @default(autoincrement())
  externalId       Int?            @unique
  name             String
  description      String          @default("")
  price            Float
  price2           Float?
  price3           Float?
  price4           Float?
  stock            Int             @default(0)
  image            String          @default("")
  barcode          String?
  available        Boolean         @default(true)
  featured         Boolean         @default(false)
  categoryId       Int
  category         Category        @relation(fields: [categoryId], references: [id])
  borgestProductId Int?
  borgestProduct   BorgestProduct? @relation(fields: [borgestProductId], references: [id], onDelete: SetNull)
  priceList        Int             @default(1)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([borgestProductId])
}

model BorgestProduct {
  id        Int       @id
  name      String
  barcode   String?
  price1    Float
  price2    Float?
  price3    Float?
  price4    Float?
  stock     Int       @default(0)
  estado    String
  foto      String?
  syncedAt  DateTime  @updatedAt
  products  Product[]
}

model Order {
  id           Int      @id @default(autoincrement())
  customerName String
  phone        String
  items        String
  total        Float
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}
